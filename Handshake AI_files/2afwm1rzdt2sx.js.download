ion CreateHarborDataset($input: CreateHarborDatasetInput!) {\n    createHarborDataset(input: $input) {\n      dataset {\n        id\n        org\n        name\n        fullName\n      }\n    }\n  }\n":nR,"\n  query HarborJob($id: ID!, $tasksFirst: Int!, $tasksAfter: String, $trialsFirst: Int!) {\n    harborJob(id: $id) {\n      id\n      name\n      status\n      datasetName\n      nTotalTrials\n      nCompletedTrials\n      nErroredTrials\n      nRunningTrials\n      nPendingTrials\n      nCancelledTrials\n      nRetries\n      totalInputTokens\n      totalCacheTokens\n      totalOutputTokens\n      totalCostUsd\n      meanReward\n      createdAt\n      startedAt\n      finishedAt\n      temporalWorkflowId\n      tasks(pagination: { first: $tasksFirst, after: $tasksAfter }) {\n        edges {\n          cursor\n          node {\n            taskName\n            nTrials\n            nSucceeded\n            nFailed\n            nRunning\n            meanReward\n            trials(pagination: { first: $trialsFirst }) {\n              edges {\n                node {\n                  id\n                  runIndex\n                  status\n                  primaryReward\n                }\n              }\n              totalCount\n            }\n          }\n        }\n        pageInfo {\n          hasNextPage\n          endCursor\n        }\n        totalCount\n      }\n    }\n  }\n":nV,"\n  query HarborJobTaskTrials($id: ID!, $taskName: String!, $trialsFirst: Int!, $trialsAfter: String) {\n    harborJob(id: $id) {\n      id\n      name\n      tasks(taskName: $taskName, pagination: { first: 1 }) {\n        edges {\n          cursor\n          node {\n            taskName\n            nTrials\n            nSucceeded\n            nFailed\n            nRunning\n            meanReward\n            trials(pagination: { first: $trialsFirst, after: $trialsAfter }) {\n              edges {\n                cursor\n                node {\n                  id\n                  trialName\n                  runIndex\n                  status\n                  modelName\n                  modelProvider\n                  primaryReward\n                  nInputTokens\n                  nOutputTokens\n                  createdAt\n                  startedAt\n                  finishedAt\n                }\n              }\n              pageInfo {\n                hasNextPage\n                endCursor\n              }\n              totalCount\n            }\n          }\n        }\n        totalCount\n      }\n    }\n  }\n":nE,"\n  query HarborTrialView($jobId: ID!, $trialId: ID!) {\n    harborJob(id: $jobId) {\n      id\n      name\n    }\n    harborTrial(id: $trialId) {\n      id\n      jobId\n      taskName\n      datasetName\n      trialName\n      runIndex\n      ordinal\n      status\n      currentPhase\n      agentName\n      agentVersion\n      modelProvider\n      modelName\n      primaryReward\n      nInputTokens\n      nCacheTokens\n      nOutputTokens\n      costUsd\n      trajectoryPath\n      errorType\n      errorMessage\n      createdAt\n      startedAt\n      finishedAt\n      rewards {\n        name\n        value\n      }\n      attempts {\n        id\n        attemptNo\n        status\n        currentPhase\n        sandboxProvider\n        sandboxRegion\n        exitCode\n        primaryReward\n        errorType\n        errorMessage\n        createdAt\n        startedAt\n        finishedAt\n      }\n      artifacts {\n        id\n        assetType\n        role\n        filename\n        contentType\n        sizeBytes\n        uri\n        status\n        createdAt\n      }\n    }\n  }\n":nC,"\n  query HarborJobs($first: Int, $after: String, $search: String) {\n    harborJobs(pagination: { first: $first, after: $after }, search: $search) {\n      edges {\n        cursor\n        node {\n          id\n          name\n          status\n          models\n          problemCount\n          nTotalTrials\n          nErroredTrials\n          meanReward\n          createdAt\n        }\n      }\n      pageInfo {\n        hasNextPage\n        hasPreviousPage\n        startCursor\n        endCursor\n      }\n      totalCount\n    }\n  }\n":nO,"\n  query HarborJobDatasets($first: Int, $search: String) {\n    harborDatasets(pagination: { first: $first }, search: $search) {\n      edges {\n        node {\n          id\n          org\n          name\n          fullName\n        }\n      }\n    }\n  }\n":nP,"\n  query HarborJobDatasetTasks($org: String!, $name: String!, $revision: Int) {\n    harborDataset(org: $org, name: $name) {\n      id\n      currentRevision {\n        id\n        revision\n        state\n      }\n      latestSealedRevision {\n        id\n        revision\n        state\n      }\n      taskVersionMembers(revision: $revision) {\n        taskVersionId\n        taskPackageId\n        taskName\n        taskFullName\n        taskRevision\n        taskContentHash\n        readiness\n      }\n    }\n  }\n":nh,"\n  query HarborDatasetForTasks($input: HarborDatasetForTasksInput!) {\n    harborDatasetForTasks(input: $input) {\n      dataset {\n        id\n        org\n        name\n        fullName\n        latestSealedRevision {\n          revision\n        }\n      }\n      tasks {\n        fullName\n        packageId\n      }\n      error {\n        code\n        message\n      }\n    }\n  }\n":nU,"\n  mutation StartHarborJob($input: StartHarborJobInput!) {\n    startHarborJob(input: $input) {\n      job {\n        id\n        name\n      }\n      workflowId\n      error {\n        code\n        message\n      }\n    }\n  }\n":n$,"\n  query HarborTask($org: String!, $name: String!, $revision: Int) {\n    harborTask(org: $org, name: $name, revision: $revision) {\n      id\n      org\n      name\n      fullName\n      description\n      taskVersionId\n      revision\n      category\n      instruction\n      readme\n      createdBy\n      createdAt\n      versions {\n        revision\n        isLatest\n      }\n      files {\n        id\n        path\n        sizeBytes\n      }\n      imageSlots {\n        role\n        built\n        registryUri\n        pushState\n        validationState\n      }\n    }\n  }\n":nB,"\n  mutation RebuildHarborImage($input: RebuildHarborImageInput!) {\n    rebuildHarborImage(input: $input) {\n      imageSlot {\n        role\n        built\n        registryUri\n        pushState\n        validationState\n      }\n      error {\n        code\n        message\n      }\n    }\n  }\n":nj,"\n  query HarborTaskFileContent($org: String!, $name: String!, $revision: Int, $path: String!) {\n    harborTaskFileContent(org: $org, name: $name, revision: $revision, path: $path)\n  }\n":nL,"\n  query HarborTasks($first: Int, $after: String, $search: String) {\n    harborTasks(pagination: { first: $first, after: $after }, search: $search) {\n      edges {\n        cursor\n        node {\n          id\n          org\n          name\n          fullName\n          description\n        }\n      }\n      pageInfo {\n        hasNextPage\n        hasPreviousPage\n        startCursor\n        endCursor\n      }\n      totalCount\n    }\n  }\n":n_,"\n  query RlePublishedEnvironmentDockerImages($input: RlePublishedEnvironmentDockerImagesInput) {\n    rlePublishedEnvironmentDockerImages(input: $input) {\n      edges {\n        cursor\n        node {\n          id\n          status\n          externalTarget\n          framework\n          monitoringEnabled\n          dockerImageUrl\n          internalDockerImageUrl\n          harness\n          fullManifest\n          cloudBuildId\n          createdAt\n          rlePublishedEnvironment {\n            id\n            rleEnvironment {\n              id\n              name\n            }\n          }\n        }\n      }\n      pageInfo {\n        hasNextPage\n        hasPreviousPage\n        startCursor\n        endCursor\n      }\n    }\n  }\n":nq,"\n  mutation RleCreateEnvironmentGroup($input: CreateRleEnvironmentGroupInput!) {\n    createRleEnvironmentGroup(input: $input) {\n      errors {\n        code\n        message\n        field\n      }\n      group {\n        id\n        name\n        members(pagination: { first: 1 }) {\n          totalCount\n        }\n      }\n    }\n  }\n":nG,"\n  mutation RleAddEnvironmentsToGroup($input: AddRleEnvironmentsToGroupInput!) {\n    addRleEnvironmentsToGroup(input: $input) {\n      errors {\n        code\n        message\n        field\n      }\n      group {\n        id\n        name\n        members(pagination: { first: 1 }) {\n          totalCount\n        }\n      }\n    }\n  }\n":nM,"\n  mutation RleRemoveEnvironmentsFromGroup($input: RemoveRleEnvironmentsFromGroupInput!) {\n    removeRleEnvironmentsFromGroup(input: $input) {\n      errors {\n        code\n        message\n        field\n      }\n      group {\n        id\n        name\n        members(pagination: { first: 1 }) {\n          totalCount\n        }\n      }\n    }\n  }\n":nx,"\n  mutation RleGenerateOvbDownloadUrl($input: GenerateOvbDownloadUrlInput!) {\n    generateOvbDownloadUrl(input: $input) {\n      downloadUrl\n      expiresAt\n    }\n  }\n":nw,"\n  query DatasetBundleName($bundleId: String!) {\n    datasetsByBundle(bundleId: $bundleId) {\n      id\n      displayName\n    }\n  }\n":nH,"\n  query RleEnvironmentGroupDetail($id: ID!, $first: Int, $after: String) {\n    rleEnvironmentGroup(id: $id) {\n      id\n      name\n      createdAt\n      updatedAt\n      creator {\n        fullName\n      }\n      members(pagination: { first: $first, after: $after }) {\n        edges {\n          node {\n            environment {\n              id\n              name\n              slug\n              persona\n              systemPrompt\n              defaultHarness\n              environmentType\n              dataHydrationMode\n              createdAt\n              updatedAt\n              creator {\n                fullName\n              }\n              tools {\n                id\n                rlToolVersion {\n                  id\n                  version\n                  tool {\n                    id\n                    name\n                  }\n                }\n              }\n              skillVersions {\n                id\n                versionNumber\n                skill {\n                  id\n                  slug\n                  displayName\n                }\n              }\n              latestSucceededOutputVersionBundle {\n                id\n              }\n              latestPublishedEnvironment {\n                id\n                createdAt\n                dockerImages {\n                  id\n                  status\n                  externalTarget\n                  framework\n                  fullManifest\n                  createdAt\n                }\n              }\n            }\n          }\n        }\n        pageInfo {\n          hasNextPage\n          endCursor\n        }\n        totalCount\n      }\n    }\n  }\n":nJ,"\n  query RleEnvironmentGroupBulkOptions($first: Int, $search: String) {\n    rleEnvironmentGroups(pagination: { first: $first }, search: $search) {\n      edges {\n        cursor\n        node {\n          id\n          name\n        }\n      }\n      pageInfo {\n        hasNextPage\n        hasPreviousPage\n        startCursor\n        endCursor\n      }\n      totalCount\n    }\n  }\n":nY,"\n  query RleEnvironmentGroups($first: Int, $after: String, $search: String) {\n    rleEnvironmentGroups(pagination: { first: $first, after: $after }, search: $search) {\n      edges {\n        node {\n          id\n          name\n          createdAt\n          updatedAt\n          creator {\n            fullName\n          }\n          members(pagination: { first: 1 }) {\n            totalCount\n          }\n        }\n      }\n      pageInfo {\n        hasNextPage\n        endCursor\n      }\n      totalCount\n    }\n  }\n":nW,"\n  query RleEnvironment($id: ID!) {\n    rleEnvironment(id: $id) {\n      id\n      name\n      slug\n      persona\n      systemPrompt\n      defaultHarness\n      defaultModel\n      environmentType\n      dataHydrationMode\n      internalVerfiedPublication\n      baseImageName\n      agentProviderOptions\n      agentConfig\n      skillVersions {\n        id\n        versionNumber\n        isLatest\n        skill {\n          id\n          displayName\n          slug\n        }\n      }\n      tools {\n        id\n        toolVersionId\n        toolOptions\n        allowedFunctions\n        rlToolVersion {\n          id\n          functions\n          tool {\n            id\n          }\n        }\n      }\n    }\n  }\n":nQ,"\n  mutation UpdateRleEnvironment($id: ID!, $input: UpdateRleEnvironmentInput!) {\n    updateRleEnvironment(id: $id, input: $input) {\n      environment {\n        id\n        name\n        slug\n        environmentType\n        dataHydrationMode\n        skillVersions {\n          id\n          versionNumber\n          isLatest\n          skill {\n            id\n            displayName\n            slug\n          }\n        }\n      }\n    }\n  }\n":nK,"\n  query RleEnvironmentDetail($id: ID!) {\n    rleEnvironment(id: $id) {\n      id\n      name\n      slug\n      persona\n      systemPrompt\n      defaultHarness\n      defaultModel\n      environmentType\n      dataHydrationMode\n      calculatedSyntheticDataGenerationStage\n      createdAt\n      updatedAt\n      creator {\n        id\n        fullName\n      }\n      datasetBundle {\n        id\n        displayName\n      }\n      latestSyntheticDataProcessingJob {\n        id\n        status\n      }\n      tools {\n        id\n        toolVersionId\n        rlToolVersion {\n          id\n          version\n          tool {\n            id\n            name\n          }\n        }\n        toolOptions\n        allowedFunctions\n        inputSource\n        syntheticDatasetId\n        dataHydrationMode\n      }\n      skillVersions {\n        id\n        versionNumber\n        skill {\n          id\n          displayName\n          slug\n        }\n      }\n      publishedEnvironments {\n        id\n        status\n        createdAt\n        updatedAt\n        dockerImages {\n          id\n          harness\n          model\n          status\n          dockerImageUrl\n          internalDockerImageUrl\n          fullManifest\n          externalTarget\n          framework\n          monitoringEnabled\n          includeBucketStaticData\n          cloudBuildId\n          createdAt\n          updatedAt\n        }\n      }\n      sandboxInstances(type: EXPLORER) {\n        id\n        provider\n        name\n        providerId\n        cpuMillicores\n        memoryBytes\n        diskBytes\n        status\n        type\n        createdAt\n        updatedAt\n        dockerImage {\n          id\n        }\n      }\n      outputVersionBundles {\n        id\n        status\n        createdBy\n        createdByProfile {\n          name\n        }\n        sourceDatasetBundles {\n          id\n          displayName\n        }\n        dataProcessingJob {\n          id\n          jobType\n        }\n        createdAt\n        updatedAt\n      }\n      dataProcessingJobs(pagination: { first: 50 }) {\n        edges {\n          node {\n            id\n            jobType\n            status\n            rleDatasetBundleId\n            createdByName\n            createdAt\n            completedAt\n          }\n        }\n      }\n    }\n  }\n":nz,"\n  mutation UpdateRleEnvironmentFromDetail($id: ID!, $input: UpdateRleEnvironmentInput!) {\n    updateRleEnvironment(id: $id, input: $input) {\n      environment {\n        id\n        tools {\n          id\n          toolVersionId\n          rlToolVersion {\n            id\n            version\n            tool {\n              id\n              name\n            }\n          }\n          toolOptions\n          allowedFunctions\n          inputSource\n        }\n      }\n    }\n  }\n":nX,"\n  mutation RequestRleSandboxUploadUrl($input: RequestRleSandboxUploadUrlInput!) {\n    requestRleSandboxUploadUrl(input: $input) {\n      uploadUrl\n      expiresAt\n      objectName\n    }\n  }\n":nZ,"\n  mutation RequestExpertInputsUploadUrl($input: RequestExpertInputsUploadUrlInput!) {\n    requestExpertInputsUploadUrl(input: $input) {\n      uploadUrl\n      expiresAt\n      objectName\n      expertInputsId\n      uploadHeaders\n    }\n  }\n":n0,"\n  mutation CreateRleEnvironmentExpertInputs($input: CreateRleEnvironmentExpertInputsInput!) {\n    createRleEnvironmentExpertInputs(input: $input) {\n      expertInputs {\n        id\n        rleEnvironmentId\n        createdAt\n        updatedAt\n      }\n    }\n  }\n":n1,"\n  mutation CreatePublishedEnvironment($input: CreatePublishedEnvironmentInput!) {\n    createPublishedEnvironment(input: $input) {\n      publishedEnvironment {\n        id\n        status\n        createdAt\n        updatedAt\n        dockerImages {\n          id\n          harness\n          model\n          status\n          dockerImageUrl\n          internalDockerImageUrl\n          fullManifest\n          externalTarget\n          framework\n          monitoringEnabled\n          includeBucketStaticData\n          cloudBuildId\n          createdAt\n          updatedAt\n        }\n      }\n    }\n  }\n":n6,"\n  mutation CreateRleSandboxInstanceExplorer($input: CreateRleSandboxInstanceExplorerInput!) {\n    createRleSandboxInstanceExplorer(input: $input) {\n      sandboxInstance {\n        id\n        provider\n        providerId\n        name\n        status\n        type\n        createdAt\n        updatedAt\n      }\n    }\n  }\n":n5,"\n  mutation CreateRleChatSessionSandbox($input: CreateRleChatSessionSandboxInput!) {\n    createRleChatSessionSandbox(input: $input) {\n      sandboxInstance {\n        id\n        provider\n        providerId\n        name\n        status\n        type\n        createdAt\n        updatedAt\n      }\n    }\n  }\n":n7,"\n  mutation RequestRleBuildVariants($input: RequestRleBuildVariantsInput!) {\n    requestRleBuildVariants(input: $input) {\n      publishedEnvironment {\n        id\n      }\n      dockerImages {\n        id\n        harness\n        model\n        status\n        dockerImageUrl\n        internalDockerImageUrl\n        fullManifest\n        externalTarget\n        framework\n        monitoringEnabled\n        includeBucketStaticData\n        cloudBuildId\n        createdAt\n        updatedAt\n      }\n    }\n  }\n":n4,"\n  mutation CancelRlePublishedEnvironmentDockerImageBuild(\n    $input: CancelRlePublishedEnvironmentDockerImageBuildInput!\n  ) {\n    cancelRlePublishedEnvironmentDockerImageBuild(input: $input) {\n      messageId\n      dockerImage {\n        id\n        status\n        cloudBuildId\n        updatedAt\n      }\n    }\n  }\n":n2,"\n  mutation StartSyntheticDataGenerate($input: StartSyntheticDataGenerateInput!) {\n    startSyntheticDataGenerate(input: $input) {\n      id\n      messageId\n      bundleId\n      expertInputsId\n      payloadJson\n    }\n  }\n":n8,"\n  mutation GenerateOvbDownloadUrl($input: GenerateOvbDownloadUrlInput!) {\n    generateOvbDownloadUrl(input: $input) {\n      downloadUrl\n      expiresAt\n    }\n  }\n":n9,"\n  mutation RequestOutputVersionBundleUploadUrl($input: RequestOutputVersionBundleUploadUrlInput!) {\n    requestOutputVersionBundleUploadUrl(input: $input) {\n      outputVersionBundle {\n        id\n      }\n      uploadUrl\n      expiresAt\n    }\n  }\n":n3,"\n  mutation UpdateOutputVersionBundleStatus($input: UpdateOutputVersionBundleStatusInput!) {\n    updateOutputVersionBundleStatus(input: $input) {\n      outputVersionBundle {\n        id\n        status\n      }\n    }\n  }\n":ie,"\n  query RleEnvironmentProblems($environmentId: ID!, $first: Int!, $after: String, $search: String) {\n    rleProblems(\n      pagination: { first: $first, after: $after }\n      search: $search\n      filters: { defaultRleEnvironmentId: $environmentId }\n    ) {\n      totalCount\n      pageInfo {\n        hasNextPage\n        endCursor\n      }\n      edges {\n        cursor\n        node {\n          id\n          objectId\n          name\n          description\n          status\n          originType\n          originRef\n          tags\n          metadata\n          createdAt\n          updatedAt\n          latestApprovedVersion {\n            id\n            versionNumber\n            status\n            prompt\n            systemPrompt\n            developerPrompt\n            metadata\n            supportingAssetIds\n            approvedAt\n            createdAt\n          }\n        }\n      }\n    }\n  }\n":ii,"\n  query RleProblemCsvUploadGroups($environmentId: ID!, $first: Int!, $after: String) {\n    rleProblemCsvUploadGroups(environmentId: $environmentId, first: $first, after: $after) {\n      pageInfo {\n        hasNextPage\n        endCursor\n      }\n      edges {\n        cursor\n        node {\n          key\n          fileName\n          importedAt\n          problemCount\n        }\n      }\n    }\n  }\n":ia,"\n  query RleProblemIdsForCsvUpload($environmentId: ID!, $importBatchId: String!) {\n    rleProblemIdsForCsvUpload(environmentId: $environmentId, importBatchId: $importBatchId)\n  }\n":id,"\n  query RleEnvironmentJobs(\n    $environmentId: ID!\n    $first: Int!\n    $after: String\n    $isAnnotationsTaskingJob: Boolean\n  ) {\n    rleProblemJobsConnection(\n      environmentId: $environmentId\n      first: $first\n      after: $after\n      isAnnotationsTaskingJob: $isAnnotationsTaskingJob\n    ) {\n      edges {\n        cursor\n        node {\n          id\n          objectId\n          name\n          status\n          backend\n          agentHarness\n          modelConfigurationId\n          rlePublishedEnvironmentDockerImageId\n          workflowId\n          taigaJobId\n          taigaJobUrl\n          metadata\n          attemptsPerRun\n          createdAt\n          updatedAt\n          runs {\n            id\n            status\n            position\n            modelConfigurationId\n            problem {\n              id\n              objectId\n              name\n            }\n            problemVersion {\n              id\n              versionNumber\n              prompt\n            }\n            attempts {\n              id\n              attemptIndex\n              status\n              rlRolloutId\n              rlRolloutExecutionId\n              trajectoryAssetId\n              score\n              failureSummary\n              error\n              updatedAt\n            }\n          }\n        }\n      }\n      pageInfo {\n        hasNextPage\n        hasPreviousPage\n        startCursor\n        endCursor\n      }\n    }\n  }\n":il,"\n  mutation CreateRleProblem($input: CreateRleProblemInput!) {\n    createRleProblem(input: $input) {\n      problem {\n        id\n        objectId\n      }\n      version {\n        id\n        versionNumber\n        status\n      }\n    }\n  }\n":it,"\n  mutation CreateRleProblems($input: CreateRleProblemsInput!) {\n    createRleProblems(input: $input) {\n      results {\n        problem {\n          id\n          objectId\n        }\n        version {\n          id\n          versionNumber\n          status\n        }\n      }\n      failures {\n        index\n        rowNumber\n        message\n      }\n    }\n  }\n":im,"\n  mutation CreateRleProblemVersion($input: CreateRleProblemVersionInput!) {\n    createRleProblemVersion(input: $input) {\n      version {\n        id\n        rleProblemId\n        versionNumber\n        status\n        prompt\n        systemPrompt\n        developerPrompt\n        approvedAt\n        createdAt\n      }\n    }\n  }\n":ik,"\n  mutation CreateRleProblemJobFromProblems($input: CreateRleProblemJobFromProblemsInput!) {\n    createRleProblemJobFromProblems(inp