  margin-left: 4px;

  /* Style the inner anchor (the actual clickable element) so that both the
     icon and the tier display name sit side-by-side inside one tappable
     target — see the cloneElement call below. */
  a {
    display: flex;
    align-items: center;
    gap: var(--rosetta-size-spacing-two);
    border-radius: var(--rosetta-size-radius-two);
    /* Suppress the default anchor underline on the wordmark text now that
       the display name lives inside the link. */
    text-decoration: none;
    color: var(--rosetta-fg-primary);
  }

  svg {
    /* Shadow uses the Rosetta fg-border color (#1F202C) at 12% so it tones
       with the rest of the chrome instead of pure black. */
    filter: drop-shadow(0 1px 2px rgba(31, 32, 44, 0.12));

    rect:first-of-type {
      stroke: var(--rosetta-fg-border);
      stroke-width: 0.5;
      vector-effect: non-scaling-stroke;
    }
  }
